{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "enabledMcpjsonServers": ["context7", "figma", "github"],
  "permissions": {
    "deny": ["Read(./.env)"]
  },
  "model": "opusplan",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "docker compose exec app npx eslint . --fix --quiet",
            "statusMessage": "Fixing ESLint issues..."
          },
          {
            "type": "command",
            "command": "docker compose exec app npx prettier --write . --log-level warn",
            "statusMessage": "Formatting code with Prettier..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/knowledge-capture-nudge.sh",
            "statusMessage": "Checking knowledge-capture obligations..."
          }
        ]
      }
    ]
  }
}
